      "item": [
        {
          "name": "Quote - Jupiter - 主币<>代币 (SOL → USDC)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestId', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Jupiter 主币<>代币 - HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.test('Jupiter 主币<>代币 - 业务码 0', function () {",
                  "  pm.expect(json.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test('Jupiter 主币<>代币 - 返回包含 Jupiter 报价', function () {",
                  "  var data = json.data || [];",
                  "  var hit = data.some(function (x) {",
                  "    var p = x && x.info && x.info.provider;",
                  "    if (!p) return false;",
                  "    var s = String(p).toLowerCase();",
                  "    return s.indexOf('jupiter') >= 0;",
                  "  });",
                  "  pm.expect(hit).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
