                  "    var ju=d.find(function(x){",
                  "      var p1=x&&x.info&&String(x.info.provider||'');",
                  "      var p2=x&&String(x.provider||'');",
                  "      return p1==='SwapJupiter' || p2==='SwapJupiter' || p1.toLowerCase().includes('jupiter') || p2.toLowerCase().includes('jupiter');",
