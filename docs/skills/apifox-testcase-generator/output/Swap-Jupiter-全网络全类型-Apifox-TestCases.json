                  "      pm.expect(ju).to.be.ok;",
                  "      pm.expect(ju.errorMessage, 'Jupiter 条目携带 errorMessage: ' + ju.errorMessage).to.be.oneOf([undefined, null, '']);",
                  "      var hasQuote=ju.toAmount||ju.fromAmount||(ju.info&&ju.info.toAmount);",
