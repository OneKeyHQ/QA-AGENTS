{
  "info": {
    "name": "Swap Jupiter - Solana 单网络全类型",
    "description": "Jupiter 渠道（Solana）API 测试用例：\n- 01-Jupiter-构建（含 Quote）：主币<>代币、代币<>主币、代币<>代币\n- 每条用例按 quote -> 提取 Jupiter quoteResultCtx -> build-tx 执行\n\n基线（来自 docs/qa/rules/swap-network-features.md）：\n- 网络 networkId: sol--101\n- userAddress / receivingAddress: 5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52\n- SOL 主币标识: 空字符串\n- USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v\n- USDT: Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB\n\n当前口径：\n- Jupiter 仅覆盖 Solana 同链\n- Jupiter 构建依赖 quoteResultCtx\n- /swap/v1/build-tx 必须返回 data.tx（Solana 序列化交易）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "requestId",
      "value": "{{$guid}}",
      "type": "string"
    },
    {
      "key": "baseUrl",
      "value": "https://swap.onekeytest.com",
      "type": "string"
    },
    {
      "key": "userAddressSolana",
      "value": "5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01-Jupiter-构建（含 Quote）",
      "item": [
        {
          "name": "Build+Quote - Jupiter - 主币<>代币 (SOL → USDC)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestId', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "/**",
                  " * Jupiter 主币<>代币：quote -> quoteResultCtx -> build-tx",
                  " */",
                  "const testCases = [{",
                  "  name: 'Solana.SOL → USDC',",
                  "  quoteParams: {",
                  "    fromTokenAddress: '',",
                  "    toTokenAddress: 'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v',",
                  "    fromTokenAmount: '0.01',",
                  "    fromNetworkId: 'sol--101',",
                  "    toNetworkId: 'sol--101',",
                  "    protocol: 'Swap',",
                  "    userAddress: '5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52',",
                  "    slippagePercentage: '0.5',",
                  "    autoSlippage: 'true',",
                  "    receivingAddress: '5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52',",
                  "    kind: 'sell',",
                  "    toTokenAmount: '',",
                  "    denySingleSwapProvider: ''",
                  "  },",
                  "  buildBase: {",
                  "    fromTokenAddress: '',",
                  "    toTokenAddress: 'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v',",
                  "    fromNetworkId: 'sol--101',",
                  "    toNetworkId: 'sol--101'",
                  "  },",
                  "  userAddr: '5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52',",
                  "  recvAddr: '5UCR1u65cKhcJCnuaRxXy9zFYXnRBZ9ArYmGah6sEB52'",
                  "}];",
                  "const QUOTE_URL = 'https://swap.onekeytest.com/swap/v1/quote';",
                  "const BUILD_URL = 'https://swap.onekeytest.com/swap/v1/build-tx';",
                  "const quoteHeaders = {",
                  "  'X-Onekey-Request-ID': pm.variables.replaceIn('{{$guid}}'),",
                  "  'X-Onekey-Request-Currency': 'usd',",
                  "  'X-Onekey-Request-Locale': 'en',",
                  "  'X-Onekey-Request-Theme': 'light',",
                  "  'X-Onekey-Request-Platform': 'android-apk',",
                  "  'X-Onekey-Request-Version': '6.1.0',",
                  "  'X-Onekey-Request-Build-Number': '2026022727'",
                  "};",
                  "const buildHeaders = {",
                  "  accept: 'application/json, text/plain, */*',",
                  "  'content-type': 'application/json',",
                  "  'X-Onekey-Request-ID': pm.variables.replaceIn('{{$guid}}'),",
                  "  'X-Onekey-Request-Currency': 'usd',",
                  "  'X-Onekey-Request-Locale': 'en',",
                  "  'X-Onekey-Request-Theme': 'light',",
                  "  'X-Onekey-Request-Platform': 'android-apk',",
                  "  'X-Onekey-Request-Version': '6.1.0',",
                  "  'X-Onekey-Request-Build-Number': '2026022727',",
                  "  'X-Onekey-Wallet-Type': 'hd'",
                  "};",
                  "function buildQuery(params){ return Object.entries(params).filter(function(kv){ return kv[1]!==undefined&&kv[1]!==null; }).map(function(kv){ return encodeURIComponent(kv[0])+'='+encodeURIComponent(String(kv[1])); }).join('&'); }",
                  "function toJsonSafe(res, label){",
                  "  var contentType = (res.headers.get && res.headers.get('Content-Type')) || '';",
                  "  pm.test('[' + label + '] 响应为 JSON', function(){ pm.expect(String(contentType).toLowerCase()).to.include('application/json'); });",
                  "  if (String(contentType).toLowerCase().indexOf('application/json') < 0) {",
                  "    console.log('[' + label + '] 非 JSON 响应:', res.text());",
                  "    return null;",
                  "  }",
                  "  return res.json();",
                  "}",
                  "function runCase(i){",
                  "  if(i>=testCases.length){ console.log('done'); return; }",
                  "  var c=testCases[i];",
                  "  var n=c.name;",
                  "  pm.sendRequest({",
                  "    url: QUOTE_URL + '?' + buildQuery(c.quoteParams),",
                  "    method: 'GET',",
                  "    header: Object.entries(quoteHeaders).map(function(e){ return { key:e[0], value:String(e[1]) }; })",
                  "  }, function(err,res){",
                  "    if(err){ pm.test('['+n+'] quote 请求失败', function(){ pm.expect.fail(err.toString()); }); runCase(i+1); return; }",
                  "    var code=res.code||res.status;",
                  "    pm.test('['+n+'] quote HTTP 200', function(){ pm.expect(code).to.equal(200); });",
                  "    if(code!==200){ console.log(res.text()); runCase(i+1); return; }",
                  "    var j=toJsonSafe(res, n + ' quote');",
                  "    if(!j){ runCase(i+1); return; }",
                  "    pm.test('['+n+'] quote 业务码 0', function(){ pm.expect(j.code).to.eql(0); });",
                  "    var d=Array.isArray(j.data)?j.data:[];",
                  "    var providers=d.map(function(x){ return (x&&x.info&&x.info.provider) || (x&&x.provider) || ''; }).filter(Boolean);",
                  "    var ju=d.find(function(x){",
                  "      var p1=x&&x.info&&String(x.info.provider||'');",
                  "      var p2=x&&String(x.provider||'');",
                  "      return p1==='SwapJupiter' || p2==='SwapJupiter' || p1.toLowerCase().includes('jupiter') || p2.toLowerCase().includes('jupiter');",
                  "    });",
                  "    pm.test('['+n+'] Jupiter 有效报价', function(){",
                  "      if(!ju){ pm.expect.fail('data 中无 Jupiter 条目，providers=' + JSON.stringify(providers)); }",
                  "      pm.expect(ju).to.be.ok;",
                  "      pm.expect(ju.errorMessage, 'Jupiter 条目携带 errorMessage: ' + ju.errorMessage).to.be.oneOf([undefined, null, '']);",
                  "      var hasQuote=ju.toAmount||ju.fromAmount||(ju.info&&ju.info.toAmount);",
                  "      pm.expect(hasQuote, 'Jupiter 条目无有效报价金额').to.be.ok;",
                  "    });",
                  "    if(!ju){ runCase(i+1); return; }",
                  "    var ctx=(ju&&ju.quoteResultCtx) || (ju&&ju.info&&ju.info.quoteResultCtx) || null;",
                  "    pm.test('['+n+'] quoteResultCtx 存在', function(){",
                  "      if(!ctx){ pm.expect.fail('jupiterQuote=' + JSON.stringify(ju)); }",
                  "      pm.expect(ctx).to.be.ok;",
                  "    });",
                  "    if(!ctx){ runCase(i+1); return; }",
                  "    var toAmt=ju.toAmount || (ju.info&&ju.info.toAmount) || '0';",
                  "    var body=Object.assign({}, c.buildBase, {",
                  "      fromTokenAmount: c.quoteParams.fromTokenAmount,",
                  "      toTokenAmount: String(toAmt),",
                  "      protocol: 'Swap',",
                  "      provider: 'SwapJupiter',",
                  "      userAddress: c.userAddr,",
                  "      receivingAddress: c.recvAddr,",
                  "      slippagePercentage: 0.5,",
                  "      kind: 'sell',",
                  "      walletType: 'hd',",
                  "      quoteResultCtx: ctx",
                  "    });",
                  "    pm.sendRequest({",
                  "      url: BUILD_URL,",
                  "      method: 'POST',",
                  "      header: Object.entries(buildHeaders).map(function(e){ return { key:e[0], value:String(e[1]) }; }),",
                  "      body: { mode: 'raw', raw: JSON.stringify(body) }",
                  "    }, function(err2,res2){",
                  "      if(err2){ pm.test('['+n+'] build 请求失败', function(){ pm.expect.fail(err2.toString()); }); runCase(i+1); return; }",
                  "      var code2=res2.code||res2.status;",
                  "      pm.test('['+n+'] build HTTP 200', function(){ pm.expect(code2).to.equal(200); });",
                  "      if(code2!==200){ console.log(res2.text()); runCase(i+1); return; }",
                  "      var j2=toJsonSafe(res2, n + ' build');",
                  "      if(!j2){ runCase(i+1); return; }",
                  "      pm.test('['+n+'] build 业务码 0', function(){ pm.expect(j2.code).to.eql(0); });",
                  "      pm.test('['+n+'] build data.tx 存在', function(){ pm.expect(j2.data).to.have.property('tx'); pm.expect(j2.data.tx).to.be.ok; });",
                  "      runCase(i+1);",
                  "    });",
                  "  });",
                  "}",
                  "runCase(0);"
                ]
              }
            }
          ],
