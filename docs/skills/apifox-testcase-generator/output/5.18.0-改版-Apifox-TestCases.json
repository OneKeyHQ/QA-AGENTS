    {
      "name": "04-Earn 模块",
      "description": "Earn 借贷服务接口",
      "item": [
        {
          "name": "01-获取 Market 列表",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestId', pm.variables.replaceIn('{{$guid}}'));",
                  "console.log('开始测试: 获取 Market 列表');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('响应状态码为 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('响应时间小于 3000ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test('业务状态码为 0', function() {",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test('data.markets 是数组且不为空', function() {",
                  "    pm.expect(jsonData.data.markets).to.be.an('array');",
                  "    pm.expect(jsonData.data.markets.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Market 包含必要字段', function() {",
                  "    const market = jsonData.data.markets[0];",
                  "    pm.expect(market).to.have.property('provider');",
                  "    pm.expect(market).to.have.property('networkId');",
                  "    pm.expect(market).to.have.property('name');",
                  "    pm.expect(market).to.have.property('address');",
                  "});",
                  "",
                  "// ★ 提取 marketAddress 到环境变量供后续接口使用",
                  "if (jsonData.data.markets && jsonData.data.markets.length > 0) {",
                  "    const market = jsonData.data.markets[0];",
                  "    pm.environment.set('marketAddress', market.address);",
                  "    pm.environment.set('provider', market.provider);",
                  "    pm.environment.set('networkId', market.networkId);",
                  "    console.log('★ 已写入环境变量:');",
                  "    console.log('  - marketAddress:', market.address);",
                  "    console.log('  - provider:', market.provider);",
                  "    console.log('  - networkId:', market.networkId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Onekey-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Currency",
                "value": "usd",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Locale",
                "value": "en",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Theme",
                "value": "light",
                "type": "text"
              },
              {
