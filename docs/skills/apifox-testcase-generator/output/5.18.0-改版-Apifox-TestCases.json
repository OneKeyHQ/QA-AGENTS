    {
      "name": "01-Wallet 模块",
      "description": "钱包核心服务接口",
      "item": [
        {
          "name": "01-健康检查",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestId', pm.variables.replaceIn('{{$guid}}'));",
                  "console.log('开始测试: Wallet 健康检查');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('响应状态码为 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('响应时间小于 3000ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test('业务状态码为 0', function() {",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test('返回数据为 ok', function() {",
                  "    pm.expect(jsonData.data).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Onekey-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Currency",
                "value": "usd",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Locale",
                "value": "en",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Theme",
                "value": "light",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Platform",
                "value": "android-apk",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Version",
                "value": "5.18.0",
                "type": "text"
              },
              {
                "key": "X-Onekey-Request-Build-Number",
                "value": "2000000000",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://api.onekey.so/wallet/v1/health",
              "protocol": "https",
              "host": ["api", "onekey", "so"],
              "path": ["wallet", "v1", "health"]
            }
          }
        },
